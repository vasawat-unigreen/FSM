# Copy to .env and fill in. See src/server/lib/env.ts for validation.

# PostgreSQL connection string.
#  - Local dev (npm run dev:db): the value below.
#  - Production: a pooled hosted Postgres URL, e.g. Neon's "-pooler" endpoint.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fsm?schema=public"

# Auth — generate with: openssl rand -base64 32  (REQUIRED in production)
AUTH_SECRET=""

# File storage for uploaded photos/signatures.
#  - unset / "disk": local ./uploads (dev, self-host with a volume)
#  - "blobs":        Netlify Blobs (Netlify deploys)
STORAGE_DRIVER=""

# Stripe (Phase 6)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
